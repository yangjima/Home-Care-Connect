# ============================================================
# 居服通 Docker Compose 环境变量配置
# 复制此文件为 .env 并修改其中的值
# cp infrastructure/docker/.env.example infrastructure/docker/.env
# ============================================================

# MySQL 数据库
MYSQL_PASSWORD=HomeCare2026@DB

# Redis 缓存
REDIS_PASSWORD=HomeCare2026@Redis

# JWT 认证
JWT_SECRET=HomeCareJWT2026SecretKeyVeryLongAndSecureDoNotShare
JWT_EXPIRATION=86400000

# MinIO 对象存储
MINIO_ROOT_USER=homecareadmin
MINIO_ROOT_PASSWORD=HomeCare2026@Minio

# 阿里云百炼 DashScope API Key（AI 服务必需）
# 请前往 https://dashscope.console.aliyun.com/ 获取 API Key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM 模型（可选，默认 qwen-plus）
# 可选值：qwen-plus, qwen-max, qwen-turbo, qwen-long
LLM_MODEL=qwen-plus
